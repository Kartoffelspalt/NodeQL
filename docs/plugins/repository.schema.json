{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodeql.dev/schemas/plugin-repository-v1.json",
  "title": "NodeQL plugin repository catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "plugins"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "name": {"type": "string", "minLength": 1},
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "version", "manifestUrl", "sha256"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:\\.[a-z0-9-]+)+$"},
          "name": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "manifestUrl": {"type": "string", "format": "uri-reference"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
